# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram user ID — get it from @userinfobot
# Set to 0 to allow any user (not recommended)
ALLOWED_USER_ID=123456789


# ── Notion ────────────────────────────────────────────────────────────────────
# Create at https://www.notion.so/my-integrations → share DB with the integration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Run setup_notion.py to auto-create the DB and get these IDs, or:
# From your database URL: notion.so/yourname/<DATABASE_ID>?v=...
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── imgbb (optional) ──────────────────────────────────────────────────────────
# Free key at https://imgbb.com — makes screenshot URLs permanent in Notion
# Leave blank to use Telegram's temp URLs (they expire after ~1 hour)
IMGBB_API_KEY=
