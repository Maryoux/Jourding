# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram user ID — get it from @userinfobot
# Set to 0 to allow any user (not recommended)
ALLOWED_USER_ID=123456789


# ── Notion ────────────────────────────────────────────────────────────────────
# Create at https://www.notion.so/my-integrations → share DB with the integration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Run setup_notion.py to auto-create the DB and get these IDs
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── imgbb (optional) ──────────────────────────────────────────────────────────
# Free key at https://imgbb.com — makes screenshot URLs permanent in Notion
# Leave blank to skip screenshot saving
IMGBB_API_KEY=


# ── OpenRouter (optional but recommended) ─────────────────────────────────────
# Enables FREE automatic Entry / SL / TP detection from chart screenshots.
# Uses NVIDIA Nemotron Nano 12B 2 VL — $0/M tokens, trained on ChartQA & OCR.
#
# 1. Sign up free at https://openrouter.ai
# 2. Go to Keys → Create key → copy it here
# 3. No credit card required for free models
#
# Leave blank to keep the original manual-entry flow.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
